# Файл конфигурации редактора nano

## Основные настройки

# Настройка для остановки команд перехода к следующему слову
# и удаления слова на границах слов, а не в их начале
# set afterends

# Настройка переноса строк по пробелам вместо края экрана
# set atblanks
# перенос строк по пробелам

# Автоматическое выравнивание отступов новой строки
set autoindent
# автоматический отступ новой строки

# Создание резервных копий файлов с добавлением тильда
# set backup
# создание резервных копий

# Директория для уникальных резервных копий
# set backupdir ""
# путь к директории резервных копий

# Использование жирного текста вместо обратного видео
# set boldtext
# жирный текст вместо инверсии

# Обработка строк с пробелами как начала абзаца
# set bookstyle
# стиль оформления абзацев

# Символы, считающиеся закрывающими скобками при выравнивании
set brackets ""')>]}"
# символы закрывающих скобок

# Автоматический перенос длинных строк
set breaklonglines

# Регистрозависимый поиск по умолчанию
# set casesensitive
# чувствительность к регистру

# Постоянное отображение позиции курсора
# set constantshow
# постоянная индикация позиции курсора

# Отображение полосы прокрутки
set indicator
# полоса прокрутки

# Прокрутка содержимого окна по полэкрана
set jumpyscrolling

# Отображение номеров строк
set linenumbers

# Включение подсветки синтаксиса для всех файлов
# Подключает все готовые файлы подсветки синтаксиса из системной директории
include "/usr/share/nano/*.nanorc"

# Подсветка на основе библиотеки libmagic
set magic


# Символы скобок для поиска парных скобок
set matchbrackets "(<[{)>]}"
# символы для поиска парных скобок

# Мини-строка состояния вместо заголовка
set minibar
# компактная строка состояния

# Отображение позиции курсора в процентах
# set positionlog
# запоминание позиции курсора

# Размер табуляции в пробелах (больше 0)
set tabsize 4
# размер табуляции

# Преобразование табуляции в пробелы
# set tabstospaces
# замена табуляции пробелами

# Отсечение пробелов при переносе строк
set trimblanks
# удаление пробелов при переносе

## Цветовое оформление

# Цвета интерфейса
set titlecolor white,blue    # цвет заголовка
set promptcolor lightwhite,lightblack    # цвет подсказок
set statuscolor white,green    # цвет строки состояния
set errorcolor brightwhite,red    # цвет ошибок
set spotlightcolor black,lime    # цвет подсветки
set selectedcolor white,white    # цвет выделенного текста
set stripecolor ,yellow    # цвет полосы
set scrollercolor cyan    # цвет индикатора прокрутки
set numbercolor cyan    # цвет номеров строк
set keycolor cyan    # цвет клавиш
set functioncolor green    # цвет функций

## Настройки клавиш

# Переопределение стандартных сочетаний клавиш
# Пример: привязка Ctrl+Z для выхода
# bind ^Z suspend main

# Поддержка мыши
set mouse
# Включение множественных буферов
set multibuffer

# Сохранение изменений при выходе без запроса
set saveonexit

# Размер табуляции
set tabsize 4
# установка размера табуляции в 4 пробела

# Преобразование табуляции в пробелы
# set tabstospaces
# замена табуляции на пробелы

# Отсечение пробелов при переносе строк
set trimblanks
# обрезка пробелов при переносе

# Специальные символы для отображения табуляции и пробелов
# set whitespace "»·"
# символы для отображения табуляции и пробелов

# Определение границ слов с учетом пунктуации
# set wordbounds

# Символы, считающиеся частью слов
# set wordchars "<_>."

# Удаление выделенного региона клавишами Backspace/Delete
set zap

# Скрытие всех панелей для увеличения области редактирования
# set zero
